#include <bits/stdc++.h>
using namespace std;

int main() {
    int n;
    cin>>n;
    vector<int> pair;
    for(int i=0;i<n;i++){
        int a,b;
        cin>>a>>b;
        if(a<=0 && b<=0){
            continue;
        }
        pair.push_back(max(a,b));
    }
    sort(pair.begin(),pair.end(),greater<int>());
    int ans=0;
    for(int i=0;i<n;i++){
        if((i+1)<=pair.size()){
            ans+=pair[i];
        }
        cout<<ans<<"\n";
    }
}
