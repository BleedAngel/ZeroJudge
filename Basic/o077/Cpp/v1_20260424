#include <bits/stdc++.h>
using namespace std;

int main() {
    int h,w,n;
    cin>>h>>w>>n;
    vector<vector<int>> s(h,vector<int> (w,0));
    int r,c,t,x;
    for(int i=0;i<n;i++){
        cin>>r>>c>>t>>x;
        for(int j=0;j<h;j++){
            for(int k=0;k<w;k++){
                if((abs(j-r)+abs(k-c))<=t){
                    s[j][k]+=x;
                }
            }
        }
    }
    for(int i=0;i<h;i++){
        for(int j=0;j<w;j++){
            cout<<s[i][j]<<" ";
        }
        cout<<"\n";
    }
}
