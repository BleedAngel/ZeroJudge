#include <bits/stdc++.h>
using namespace std;

int main() {
    int n,d;
    cin>>n>>d;
    vector<vector<int>> lst(n,vector<int>(3));
    for(int i=0;i<n;i++){
        for(int j=0;j<3;j++){
            cin>>lst[i][j];
        }
    }
    int summary=0,item=0;
    for(int i=0;i<n;i++){
        int x=*max_element(lst[i].begin(),lst[i].end())-*min_element(lst[i].begin(),lst[i].end());
        if(x>=d){
            summary+=accumulate(lst[i].begin(),lst[i].end(),0)/3;
            item+=1;
        }
    }
    cout<<item<<" "<<summary;
}
