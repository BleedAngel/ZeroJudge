#include <bits/stdc++.h>
using namespace std;

int main() {
    int k;
    cin>>k;
    vector<vector<int>> lst(k);
    
    cin.ignore();
    string line;
    for(int i=0;i<k;i++){
        getline(cin,line);
        stringstream ss(line);
        int num;
        while(ss>>num){
            lst[i].push_back(num);
        }
    }
    int error=0;
    for(int i=0;i<k;i++){
        if(lst[i][1]==-1){
            error++;
        }
    }
    auto ma=max_element(
        lst.begin(),
        lst.end(),
        [](const vector<int>& a,const vector<int>& b){
            return a[1]<b[1];
        }
    );
    int score=(*ma)[1]-k-error*2;
    if(score<0){
        score=0;
    }
    cout<<score<<" "<<(*ma)[0];
}
