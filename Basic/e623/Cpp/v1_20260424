#include <bits/stdc++.h>
using namespace std;

int main() {
    int k;
    cin>>k;
    int n=1;
    while(true){
        int i=2*n*(n+1);
        if(i>k){
            break;
        }
    }
    int a=(k-2*n*(n-1))/n;
    vector<string> s={"Pen","Pineapple","Apple","Pineapple pen"};
    cout<<s[a];
}
